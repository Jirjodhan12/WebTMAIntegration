@model List<BuildingViewModel>

<div class="container mt-4">

    <h2 class="mb-3">Buildings</h2>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">

            <table class="table table-bordered table-striped table-hover align-middle">

                <thead class="table-dark">
                    <tr>
                        <th>Building Id</th>
                        <th>Campus Name</th>
                        <th>Campus Code</th>
                        <th>Building Name</th>
                        <th>Buiding Code</th>
                        <th>Building Type Id</th>
                        <th>Address</th>
                        <th>Created By</th>
                        <th>Created Date</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@item.BuildingId</td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.SiteName)
                                    ? "TEST-CAMPUS" : item.SiteName)
                            </td>
                            <td>
                                @(string.IsNullOrWhiteSpace(item.SiteCodeValue)
                                    ? "TEST-CODE" : item.SiteCodeValue)
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.BuildingName)
                                    ? "TEST-BUILDING" : item.BuildingName)
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.BuildingCode)
                                    ? "TEST-BUILDING" : item.BuildingCode)
                            </td>

                            <td>
                                @item.BuildingTypeId
                            </td>


                            <td>
                                @(
                                    string.IsNullOrWhiteSpace(item.Address) 
                                    ? "-"
                                    : item.Address
                                    )
                            </td>


                            <td>
                                @item.CreatedBy
                            </td>

                            <td>
                                @(item.CreateDate.ToString("dd-MMM-yyyy") ?? "")
                            </td>


                            <td>
                                @if (item.IsActive == true)
                                {
                                    <span class="badge bg-success">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        Inactive
                                    </span>
                                }
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>
    }
    else
    {
        <div class="alert alert-warning">
            No building records found.
        </div>
    }

</div>