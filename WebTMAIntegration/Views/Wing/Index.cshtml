@model List<WingViewModel>

<div class="container mt-4">

    <h2 class="mb-3">Rooms</h2>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">

            <table class="table table-bordered table-striped table-hover align-middle">

                <thead class="table-dark">
                    <tr>
                        <th>Wing Id</th>
                        <th>Camous Name</th>
                        <th>Building Name</th>
                        <th>Floor Name</th>
                        <th>Wing Name</th>
                        <th>Wing Type</th>
                        <th>Wing Code</th>
                        <th>Address</th>
                        <th>Created By</th>
                        <th>Created Date</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@item.WingId</td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.SiteName)
                                    ? "-"
                                    : item.SiteName)
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.BuildingName)
                                    ? "-"
                                    : item.BuildingName)
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.FloorName)
                                    ? "-"
                                    : item.FloorName)
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.WingName)
                                    ? "-"
                                    : item.WingName)
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.WingType)
                                    ? "-"
                                    : item.WingType)
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.Code)
                                    ? "-"
                                    : item.Code)
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.Address)
                                    ? "-"
                                    : item.Address)
                            </td>

                            <td>
                                @(item.CreatedBy?.ToString() ?? "-")
                            </td>

                            <td>
                                @item.CreateDate.ToString("dd-MMM-yyyy")
                            </td>

                            <td>
                                @if (item.IsActive == true)
                                {
                                    <span class="badge bg-success">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        Inactive
                                    </span>
                                }
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>
    }
    else
    {
        <div class="alert alert-warning">
            No wing records found.
        </div>
    }

</div>