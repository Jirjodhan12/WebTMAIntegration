@model List<FloorViewModel>

<div class="container mt-4">

    <h2 class="mb-3">Floors</h2>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">

            <table class="table table-bordered table-striped table-hover align-middle">

                <thead class="table-dark">
                    <tr>
                        <th>Floor Id</th>
                        <th>Campus Name</th>
                        <th>Campus Code</th>
                        <th>Building Name</th>
                        <th>Buiding Code</th>
                        <th>Floor Code</th>
                        <th>Floor Name</th>
                        <th>Address</th>
                        <th>Created By </th>
                        <th>Created Date</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                @(item.FloorId)
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.SiteName)
                                    ? "TEST-CAMPUS"
                                    : item.SiteName)
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.SiteCode)
                                    ? "TEST-CODE"
                                    : item.SiteCode)
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.BuildingName)
                                    ? "TEST-BUILDING"
                                    : item.BuildingName)
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.BuildingCode)
                                    ? "TEST-BUILDING-CODE"
                                    : item.BuildingCode)
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.FloorCode)
                                    ? "TEST-FLOOR"
                                    : item.FloorCode)
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.FloorName)
                                    ? "TEST-FLOOR"
                                    : item.FloorName)
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.Address)
                                    ? "TEST-FLOOR"
                                    : item.Address)
                            </td>

                            <td>
                                @(item.CreatedBy)
                            </td>

                            <td>
                                @(item.CreateDate.ToString("dd-MMM-yyyy") ?? "-")
                            </td>

                            <td>
                                @if (item.IsActive ?? false)
                                {
                                    <span class="badge bg-success">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        Inactive
                                    </span>
                                }
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>
    }
    else
    {
        <div class="alert alert-warning">
            No floor records found.
        </div>
    }

</div>