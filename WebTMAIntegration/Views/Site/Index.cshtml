@model List<SiteViewModel>

<div class="container mt-4">

    <h2 class="mb-3">Campus</h2>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">

            <table class="table table-bordered table-striped table-hover align-middle">

                <thead class="table-dark">
                    <tr>
                        <th>Site Id</th>
                        <th>Region Id</th>
                        <th>Campus Name</th>
                        <th>Campus Code</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Address</th>
                        <th>CreatedDate</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                @(item.SiteId.ToString() ?? "-")
                            </td>

                            <td>
                                @(item.RegionsId.ToString() ?? "-")
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.Name)  ? "-" : item.Name)
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.Code)   ? "-"  : item.Code)
                            </td>

                            <td>
                                @(string.IsNullOrWhiteSpace(item.Description) ? "-" : item.Description)
                            </td>

                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        Inactive
                                    </span>
                                }
                            </td>
                            <td>
                                @(string.IsNullOrWhiteSpace(item.Address) ? "-" : item.Address)
                            </td>

                            <td>
                                @(item.CreatedDate?.ToString("dd-MMM-yyyy") ?? "")
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>
    }
    else
    {
        <div class="alert alert-warning">
            No site records found.
        </div>
    }

</div>